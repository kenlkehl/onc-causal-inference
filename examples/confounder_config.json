{
  "output_dir": "./cdt_results_confounder",
  "seed": 42,
  "device": "cuda:0",
  "num_workers": 4,

  "applied_inference": {
    "dataset_path": "./data/clinical_notes.parquet",
    "text_column": "clinical_text",
    "outcome_column": "outcome_indicator",
    "treatment_column": "treatment_indicator",
    "split_column": "split",
    "cv_folds": 5,

    "architecture": {
      "model_type": "rlearner",
      "feature_extractor_type": "confounder",

      "confounder_num_latents": 4,
      "confounder_explicit_texts": [
        "metastatic disease",
        "performance status",
        "prior treatment history",
        "comorbidities"
      ],
      "confounder_value_dim": 128,
      "confounder_sentence_model": "all-MiniLM-L6-v2",
      "confounder_freeze_encoder": true,
      "confounder_max_sentences": 100,
      "confounder_num_heads": 4,
      "confounder_num_iterations": 2,
      "confounder_use_self_attention": true,
      "confounder_sparse_attention": true,
      "confounder_sparse_method": "entmax",
      "confounder_sparse_alpha": 1.5,
      "confounder_top_k": 5,
      "confounder_dropout": 0.1,

      "dragonnet_representation_dim": 128,
      "dragonnet_hidden_outcome_dim": 64,
      "dragonnet_dropout": 0.2
    },

    "training": {
      "epochs": 50,
      "batch_size": 8,
      "learning_rate": 0.0001,
      "optimizer": "adamw",
      "lr_schedule": "linear",
      "alpha_propensity": 1.0,
      "beta_targreg": 0.1,
      "gamma_rlearner": 1.0,
      "weight_decay": 0.01,
      "gradient_clip_norm": 1.0,
      "label_smoothing": 0.0
    },

    "use_pretrained_weights": false,

    "matching_analysis": {
      "enabled": true,
      "method": "nearest",
      "caliper": 0.2,
      "caliper_scale": "std",
      "ratio": 1,
      "replacement": false,
      "n_bootstrap": 1000,
      "ci_level": 0.95
    }
  },

  "plasmode_experiments": {
    "enabled": false,
    "num_repeats": 3,
    "save_datasets": false,
    "train_fraction": 0.8,
    "generator_architecture": {
      "model_type": "rlearner",
      "feature_extractor_type": "confounder",
      "confounder_num_latents": 4,
      "confounder_value_dim": 128,
      "confounder_num_iterations": 2,
      "confounder_sparse_attention": true,
      "dragonnet_representation_dim": 128,
      "dragonnet_hidden_outcome_dim": 64
    },
    "generator_training": {
      "learning_rate": 0.0001,
      "epochs": 20,
      "batch_size": 8,
      "alpha_propensity": 1.0,
      "beta_targreg": 0.1,
      "gamma_rlearner": 1.0
    },
    "evaluator_architecture": {
      "model_type": "rlearner",
      "feature_extractor_type": "confounder",
      "confounder_num_latents": 4,
      "confounder_value_dim": 128,
      "confounder_num_iterations": 2,
      "confounder_sparse_attention": true,
      "dragonnet_representation_dim": 128,
      "dragonnet_hidden_outcome_dim": 64
    },
    "evaluator_training": {
      "learning_rate": 0.0001,
      "epochs": 20,
      "batch_size": 8,
      "alpha_propensity": 1.0,
      "beta_targreg": 0.1,
      "gamma_rlearner": 1.0
    },
    "plasmode_scenarios": [
      {
        "generation_mode": "phi_linear",
        "preserve_observed_treatments": true,
        "baseline_control_outcome_rate": 0.2,
        "target_ate_prob": 0.10,
        "outcome_heterogeneity_scale": 1.0,
        "ite_heterogeneity_scale": 1.0
      }
    ]
  }
}
