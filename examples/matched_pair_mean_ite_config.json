{
  "output_dir": "../pcori_experiments/matched_pair_mean_ite_results_gru_unfrozen_base_ten_confounders",
  "seed": 42,
  "device": "cuda:1",
  "num_workers": 1,

  "matched_pair": {
    "dataset_path": "./example_synthetic_data_ten_confounders/dataset.parquet",
    "text_column": "clinical_text",
    "treatment_column": "treatment_indicator",
    "outcome_column": "outcome_indicator",

    "chunk_encoder": "gru",
    "gru_chunk_size": 128,
    "gru_chunk_overlap": 32,
    "gru_embedding_dim": 128,
    "gru_hidden_dim": 128,
    "gru_num_layers": 2,
    "gru_max_vocab_size": 10000,
    "gru_min_word_freq": 2,

    "hier_transformer_max_sentences": 100,
    "hier_transformer_num_layers": 2,
    "hier_transformer_num_heads": 4,
    "hier_transformer_dim": 256,
    "hier_transformer_dropout": 0.1,

    "representation_dim": 256,

    "propensity_epochs": 15,
    "propensity_lr": 5e-5,
    "propensity_batch_size": 32,
    "propensity_early_stopping_patience": 10,

    "matching_method": "embedding",
    "matching_algorithm": "optimal",
    "caliper": 0.2,
    "caliper_scale": "std",

    "outcome_epochs": 50,
    "outcome_lr": 5e-5,
    "outcome_batch_size": 32,
    "hidden_outcome_dim": 128,
    "dropout": 0.0,
    "alpha_outcome": 1.0,
    "beta_tau": 1.0,

    "cv_folds": 5,

    "joint_outcome_training": true,
    "alpha_propensity_stage1": 1.0,
    "alpha_outcome_stage1": 1.0,
    "freeze_representation_stage2": false,

    "end_to_end_training": false,

    "use_mean_embedding_ite": true,
    "mean_ite_hidden_dim": 128,
    "mean_ite_dropout": 0.0
  },

  "applied_inference": {
    "skip": true
  },

  "plasmode_experiments": {
    "enabled": false
  }
}
