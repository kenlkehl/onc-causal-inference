{
  "applied_inference": {
    "architecture": {
      "model_type": "rlearner",
      "feature_extractor_type": "hierarchical_llm",
      "hlm_model_name": "Qwen/Qwen3-0.6B-Base",
      "hlm_chunk_size": 2048,
      "hlm_chunk_overlap": 256,
      "hlm_max_chunks": 16,
      "hlm_freeze_llm": true,
      "hlm_gated_attention_dim": 128,
      "hlm_projection_dim": 128,
