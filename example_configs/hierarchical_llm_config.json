      "hlm_dropout": 0.1,
      "hlm_gradient_checkpointing": true,
      "hlm_cache_hidden_states": false
    },
    "training": {
      "learning_rate": 1e-4,
      "epochs": 20,
      "batch_size": 2,
      "alpha_propensity": 1.0,
      "gamma_rlearner": 1.0,
      "weight_decay": 0.01,
      "gradient_clip_norm": 1.0
    }
  }
}
