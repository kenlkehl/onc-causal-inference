{
  "output_dir": "./oci_results_tfidf_baseline",
  "seed": 42,
  "device": "cpu",
  "num_workers": 1,
  "save_filter_interpretations": false,
  "save_confounder_interpretations": false,

  "applied_inference": {
    "dataset_path": "../example_synthetic_data_ten_confounders_50K_rows/dataset.parquet",
    "text_column": "clinical_text",
    "outcome_column": "outcome_indicator",
    "treatment_column": "treatment_indicator",
    "cv_folds": 5,

    "architecture": {
      "model_type": "tfidf_forest",

      "tfidf_forest": {
        "max_features": 10000,
        "ngram_range_min": 1,
        "ngram_range_max": 2,
        "min_df": 5,
        "max_df": 0.95,
        "sublinear_tf": true,
        "n_estimators": 200,
        "max_depth": null,
        "min_samples_leaf": 10,
        "max_features_forest": "sqrt",
        "honest": true,
        "inference": true
      }
    },

    "training": {
      "epochs": 1,
      "batch_size": 1
    }
  },

  "plasmode_experiments": {
    "enabled": false
  }
}
