{
  "output_dir": "./cdt_results_dr_moce",
  "seed": 42,
  "device": "cuda:0",
  "num_workers": 5,

  "applied_inference": {
    "dataset_path": "./data/clinical_notes.parquet",
    "text_column": "clinical_text",
    "outcome_column": "outcome_indicator",
    "treatment_column": "treatment_indicator",
    "split_column": "split",
    "cv_folds": 5,

    "architecture": {
      "model_type": "dr_moce",
      "feature_extractor_type": "gru_pool",

      "gru_pool_embedding_dim": 128,
      "gru_pool_gru_hidden_dim": 128,
      "gru_pool_gru_num_layers": 1,
      "gru_pool_gru_bidirectional": true,
      "gru_pool_gru_dropout": 0.1,
      "gru_pool_max_chunks": 100,
      "gru_pool_chunk_size": 128,
      "gru_pool_chunk_overlap": 32,
      "gru_pool_transformer_layers": 2,
      "gru_pool_transformer_heads": 4,
      "gru_pool_transformer_dim": 256,
      "gru_pool_gated_attention_dim": 128,
      "gru_pool_projection_dim": 128,
      "gru_pool_max_vocab": 50000,
      "gru_pool_min_word_freq": 2,

      "causal_head_representation_dim": 128,
      "causal_head_hidden_outcome_dim": 64,
      "causal_head_dropout": 0.2,

      "dr_moce_num_experts": 8,
      "dr_moce_router_temperature": 1.0,
      "dr_moce_propensity_clip": 0.01,
      "dr_moce_het_weight": 0.1,
      "dr_moce_balance_weight": 0.01,
      "dr_moce_crossfit_buffer_size": 1024
    },

    "training": {
      "epochs": 50,
      "batch_size": 8,
      "learning_rate": 0.0001,
      "optimizer": "adamw",
      "lr_schedule": "linear",
      "alpha_propensity": 1.0,
      "beta_targreg": 0.0,
      "gamma_dr": 1.0,
      "weight_decay": 0.01,
      "gradient_clip_norm": 1.0,
      "label_smoothing": 0.0
    },

    "use_pretrained_weights": false,

    "matching_analysis": {
      "enabled": true,
      "method": "nearest",
      "caliper": 0.2,
      "caliper_scale": "std",
      "ratio": 1,
      "replacement": false,
      "n_bootstrap": 1000,
      "ci_level": 0.95
    }
  },

  "plasmode_experiments": {
    "enabled": false,
    "num_repeats": 3,
    "save_datasets": false,
    "train_fraction": 0.8,
    "generator_architecture": {
      "model_type": "dr_moce",
      "feature_extractor_type": "gru_pool",
      "gru_pool_embedding_dim": 128,
      "gru_pool_gru_hidden_dim": 128,
      "gru_pool_chunk_size": 128,
      "gru_pool_transformer_layers": 2,
      "gru_pool_transformer_dim": 256,
      "causal_head_representation_dim": 128,
      "causal_head_hidden_outcome_dim": 64,
      "dr_moce_num_experts": 8
    },
    "generator_training": {
      "learning_rate": 0.0001,
      "epochs": 20,
      "batch_size": 8,
      "alpha_propensity": 1.0,
      "gamma_dr": 1.0
    },
    "evaluator_architecture": {
      "model_type": "dr_moce",
      "feature_extractor_type": "gru_pool",
      "gru_pool_embedding_dim": 128,
      "gru_pool_gru_hidden_dim": 128,
      "gru_pool_chunk_size": 128,
      "gru_pool_transformer_layers": 2,
      "gru_pool_transformer_dim": 256,
      "causal_head_representation_dim": 128,
      "causal_head_hidden_outcome_dim": 64,
      "dr_moce_num_experts": 8
    },
    "evaluator_training": {
      "learning_rate": 0.0001,
      "epochs": 20,
      "batch_size": 8,
      "alpha_propensity": 1.0,
      "gamma_dr": 1.0
    },
    "plasmode_scenarios": [
      {
        "generation_mode": "phi_linear",
        "preserve_observed_treatments": true,
        "baseline_control_outcome_rate": 0.2,
        "target_ate_prob": 0.10,
        "outcome_heterogeneity_scale": 1.0,
        "ite_heterogeneity_scale": 1.0
      }
    ]
  }
}
