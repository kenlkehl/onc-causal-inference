{
  "output_dir": "./cdt_results_transformer_pool",
  "seed": 42,
  "device": "cuda:0",
  "num_workers": 4,
  "save_confounder_interpretations": true,
  "confounder_interpretation_top_k": 5,

  "applied_inference": {
    "dataset_path": "./dataset.parquet",
    "text_column": "clinical_text",
    "outcome_column": "outcome_indicator",
    "treatment_column": "treatment_indicator",
    "cv_folds": 5,
    "architecture": {
      "model_type": "rlearner",
      "feature_extractor_type": "transformer_pool",

      "tp_embedding_dim": 128,
      "tp_token_transformer_layers": 2,
      "tp_token_transformer_heads": 4,
      "tp_token_transformer_dim": 256,
      "tp_token_transformer_dropout": 0.1,
      "tp_chunk_transformer_layers": 2,
      "tp_chunk_transformer_heads": 4,
      "tp_chunk_transformer_dim": 256,
      "tp_chunk_transformer_dropout": 0.1,
      "tp_gated_attention_dim": 128,
      "tp_projection_dim": 128,
      "tp_chunk_size": 128,
      "tp_chunk_overlap": 32,
      "tp_max_chunks": 100,
      "tp_max_vocab": 50000,
      "tp_min_word_freq": 2,

      "clam_enabled": false,
      "clam_num_instances": 5,
      "clam_instance_hidden_dim": 64,

      "causal_head_representation_dim": 128,
      "causal_head_hidden_outcome_dim": 64,
      "causal_head_dropout": 0.2
    },
    "training": {
      "learning_rate": 1e-4,
      "optimizer": "adamw",
      "lr_schedule": "linear",
      "epochs": 50,
      "batch_size": 8,
      "alpha_propensity": 1.0,
      "beta_targreg": 0.0,
      "gamma_rlearner": 1.0,
      "weight_decay": 0.01,
      "gradient_clip_norm": 1.0,
      "stop_grad_propensity": false,
      "attention_entropy_weight": 0.0,
      "clam_instance_weight": 0.5
    },
    "propensity_trimming": {
      "enabled": false,
      "min_propensity": 0.1,
      "max_propensity": 0.9,
      "cv_folds": 5,
      "propensity_epochs": 20
    },
    "matching_analysis": {
      "enabled": false
    }
  },

  "plasmode_experiments": {
    "enabled": false
  }
}
